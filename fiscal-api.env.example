# Copie para fiscal-api.env e reinicie: npm run fiscal-api
# No PowerShell: Get-Content fiscal-api.env | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2].Trim('"'), 'Process') } }

# --- SPED: download automático (opcional) ---
# Sem estas variáveis, o botão "Baixar SPED" só valida o certificado.
# Importe os .txt com "Carregar TXT da pasta" (PGD, Domínio, e-CAC, etc.).

# Integra Contador (Serpro) — requer contrato e IDs dos serviços SPED
# INTEGRA_CONTADOR_CLIENT_ID=
# INTEGRA_CONTADOR_CLIENT_SECRET=
# INTEGRA_CONTADOR_CONTRATANTE_CNPJ=00000000000000
# SPED_CONTRIB_ID_SISTEMA=
# SPED_CONTRIB_ID_SERVICO=
# SPED_ICMS_ID_SISTEMA=
# SPED_ICMS_ID_SERVICO=

# Gateway corporativo (URL HTTPS que recebe JSON + certificado mTLS e devolve o TXT)
# SPED_CONTRIB_ENDPOINT=https://seu-erp/api/sped/contrib
# SPED_ICMS_ENDPOINT=https://seu-erp/api/sped/icms

# --- ICMS interestadual / DIFAL (SEFAZ SVRS + CONFAZ) ---
# Endpoints: GET /sefaz/icms/catalogo, GET /sefaz/icms/comparar?ufOrigem=SP&ufDestino=RJ&valorBase=1000
# POST /sefaz/icms/sync (verifica Portal DIFAL SVRS e CONFAZ)

# --- Regras Receita Federal (catálogo + sync CNPJ via BrasilAPI) ---
# Endpoints: GET /receita-federal/catalogo, POST /receita-federal/sync
# Calculadora oficial Reforma Tributária (componente local RFB — URL opcional):
# RECEITA_CALCULADORA_URL=http://127.0.0.1:8080
