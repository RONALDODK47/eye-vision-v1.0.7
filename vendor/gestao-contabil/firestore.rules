rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isTaskCompletionOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "completed",
        "completed_date",
        "completed_months",
        "updated_at"
      ]);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    // Leitura entre usuários logados: visão consolidada (aba Usuários). Escrita só do dono.
    match /user_profiles/{profileId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.auth.uid == profileId
        && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated()
        && request.auth.uid == profileId
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // gc_username_registry - registo de usernames
    match /gc_username_registry/{usernameKey} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        isBootstrapCloudAdmin() || isCloudMasterUser()
      );
    }

    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && (
          request.auth.uid == inovCalendarOwnerUidRule()
          || isBootstrapCloudAdmin()
          || isCloudMasterUser()
          || hasCloudClientFlag("allow_company_create")
        );
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && (
          request.auth.uid == inovCalendarOwnerUidRule()
          || isBootstrapCloudAdmin()
          || isCloudMasterUser()
          || hasCloudClientFlag("allow_task_create")
          || hasCloudClientFlag("allow_task_edit")
        );
      allow update: if isAuthenticated() && (
        (
          resource.data.uid == request.auth.uid
          && request.resource.data.uid == request.auth.uid
        )
        ||
        (
          resource.data.responsible_uid == request.auth.uid
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.responsible_uid == resource.data.responsible_uid
          && isTaskCompletionOnlyUpdate()
        )
      );
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /task_templates/{templateId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /custom_columns/{columnId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /app_settings/{settingId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /company_files/{fileId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /client_service_ratings/{ratingId} {
      allow read: if isAuthenticated()
        && resource.data.client_uid == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.client_uid == request.auth.uid
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update: if isAuthenticated()
        && resource.data.client_uid == request.auth.uid
        && request.resource.data.client_uid == request.auth.uid
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow delete: if false;
    }

    match /conversation_threads/{threadId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /conversation_messages/{messageId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Leitura partilhada no projeto (iguais aos `companies`); escrita apenas do criador (`uid`) ou administradores.
    match /notices/{noticeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid
        || isBootstrapCloudAdmin() || isCloudMasterUser()
      );
      allow delete: if isAuthenticated() && (
        resource.data.uid == request.auth.uid
        || isBootstrapCloudAdmin() || isCloudMasterUser()
      );
    }

    match /useful_sites/{siteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid
        || isBootstrapCloudAdmin() || isCloudMasterUser()
      );
      allow delete: if isAuthenticated() && (
        resource.data.uid == request.auth.uid
        || isBootstrapCloudAdmin() || isCloudMasterUser()
      );
    }

    match /loan_controls/{loanId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Chat direto entre dois usuários (participantes no array; id do tópico = uidMenor__uidMaior)
    match /direct_chat_threads/{threadId} {
      // getDoc em tópico ainda inexistente: resource é null — sem isto, ensure() falha antes do setDoc.
      allow read: if isAuthenticated()
        && (
          !exists(/databases/$(database)/documents/direct_chat_threads/$(threadId))
          || request.auth.uid in resource.data.participants
        );
      allow create: if isAuthenticated()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants;
      // Permite atualizar metadados/unread sem exigir mesma ordem do array participants (evita falha silenciosa no cliente).
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants is list
        && resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && resource.data.participants.size() == 2
        && request.resource.data.participants[0] in resource.data.participants
        && request.resource.data.participants[1] in resource.data.participants;
      allow delete: if false;
    }

    // Conclusões do calendário INOV (cada utilizador só vê e edita os seus registos).
    match /calendar_inov_completions/{compId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.deadline_id is string
        && request.resource.data.completed_on is string;
      allow update: if isAuthenticated()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.deadline_id is string
        && request.resource.data.completed_on is string;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // UID do proprietário do calendário INOV — deve coincidir com VITE_INOV_CALENDAR_OWNER_UID no build.
    function inovCalendarOwnerUidRule() {
      return "SIttoSfDngfKGuPENEgRClzdIQZ2";
    }

    // ACL do calendário INOV: metadados do dono; só o owner_uid grava a planilha na nuvem.
    match /inov_calendar_acl/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && docId == "config"
        && request.auth.uid == inovCalendarOwnerUidRule()
        && request.resource.data.owner_uid == request.auth.uid
        && request.resource.data.owner_uid is string
        && request.resource.data.editor_uids is list
        && request.resource.data.editor_uids.size() <= 40;
      allow update: if isAuthenticated()
        && docId == "config"
        && resource.data.owner_uid == request.auth.uid
        && request.resource.data.owner_uid == request.auth.uid
        && request.resource.data.owner_uid is string
        && request.resource.data.editor_uids is list
        && request.resource.data.editor_uids.size() <= 40;
      allow delete: if false;
    }

    function inovCalendarAclConfigPath() {
      return /databases/$(database)/documents/inov_calendar_acl/config;
    }

    function canWriteInovCalendarSnapshot() {
      return exists(inovCalendarAclConfigPath())
        && request.auth.uid == get(inovCalendarAclConfigPath()).data.owner_uid;
    }

    function cloudAccessConfigPath() {
      return /databases/$(database)/documents/cloud_access_control/config;
    }

    function authEmailRule() {
      return request.auth.token.email is string ? request.auth.token.email : "";
    }

    function authEmailNormalizedRule() {
      // Firestore Rules não possui função built-in para lowercase.
      // Mantemos o e-mail bruto do token.
      return authEmailRule();
    }

    function isBootstrapCloudAdmin() {
      return authEmailNormalizedRule() == "ronaldojunior.gyn@gmail.com"
        || authEmailNormalizedRule() == "ronaldojunior.gyn@usuario.local"
        || authEmailNormalizedRule() == "ronaldojunior.gyn.emergencia@usuario.local";
    }

    function hasCloudClientFlag(flagName) {
      return exists(cloudAccessConfigPath())
        && authEmailNormalizedRule() != ""
        && get(cloudAccessConfigPath()).data.clients[authEmailNormalizedRule()] is map
        && get(cloudAccessConfigPath()).data.clients[authEmailNormalizedRule()][flagName] == true;
    }

    function isCloudMasterUser() {
      return exists(cloudAccessConfigPath())
        && authEmailNormalizedRule() != ""
        && get(cloudAccessConfigPath()).data.clients[authEmailNormalizedRule()] is map
        && get(cloudAccessConfigPath()).data.clients[authEmailNormalizedRule()].is_master == true;
    }

    // Controle da Gestão Empresarial (tokens / pagamento / permissões).
    // Leitura pública (para validação do ID da empresa na criação da conta); escrita apenas do administrador (UID fixo).
    match /cloud_access_control/{docId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if false;
    }

    /** Mapa público slug → empresa (portal convite empresa). Leitura anónima para landing; escrita só admin cloud. */
    match /portal_public_aliases/{slug} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && (
        isBootstrapCloudAdmin() || isCloudMasterUser()
      );
    }

    // Overrides por linha do calendário INOV (texto / data / legenda lateral).
    match /inov_calendar_data/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if false;
    }

    // Dados operacionais Eye Vision (Gerencial, Precificação, Empréstimos) por escritório.
    match /eye_vision_office/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated()
        && request.resource.data.updated_by == request.auth.uid;
      allow delete: if false;
    }

    match /eye_vision_manager/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated()
        && request.resource.data.updated_by == request.auth.uid;
      allow delete: if false;
    }

    match /direct_chat_messages/{msgId} {
      function participantsOfThread(tid) {
        return get(/databases/$(database)/documents/direct_chat_threads/$(tid)).data.participants;
      }
      allow read: if isAuthenticated()
        && resource.data.thread_id is string
        && request.auth.uid in participantsOfThread(resource.data.thread_id);
      allow create: if isAuthenticated()
        && request.resource.data.thread_id is string
        && request.resource.data.sender_uid == request.auth.uid
        && request.auth.uid in participantsOfThread(request.resource.data.thread_id)
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 8000;
      // Edição e exclusão "para todos": apenas quem enviou a mensagem ou administradores podem alterar/remover.
      allow update: if isAuthenticated()
        && (resource.data.sender_uid == request.auth.uid || isBootstrapCloudAdmin() || isCloudMasterUser())
        && request.resource.data.sender_uid == resource.data.sender_uid
        && request.resource.data.thread_id == resource.data.thread_id
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 8000;
      allow delete: if isAuthenticated()
        && (resource.data.sender_uid == request.auth.uid || isBootstrapCloudAdmin() || isCloudMasterUser());
    }

    // Regra de contingência: desbloqueia leitura para todos e escrita apenas para administradores.
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isBootstrapCloudAdmin() || isCloudMasterUser());
    }
  }
}
