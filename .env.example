# GEMINI_API_KEY: monitoramento OCR, diagnóstico de extrato e erros do software.
# Crie em https://aistudio.google.com/apikey e coloque em .env (nunca commite a chave real).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Modelo Gemini — SOMENTE free tier (padrão: gemini-2.5-flash).
# NÃO use gemini-2.0-flash — cota zero no plano gratuito.
# Opções válidas: gemini-2.5-flash | gemini-2.5-flash-lite | gemini-flash-latest
GEMINI_MODEL="gemini-2.5-flash"

# Porta da API agente local (:8790) — Gemini + Ollama
# AGENT_API_PORT=8790

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# OCR remoto para deploy/static hosting.
# Firebase Hosting nao sobe o processo Python local; informe a URL HTTPS do servico Surya OCR remoto.
# Exemplo: VITE_SURYA_OCR_URL="https://ocr.seudominio.com"
VITE_SURYA_OCR_URL=""

# Google Custom Search — preços de insumos/MP (Automatizar na Precificação)
GOOGLE_API_KEY=""
GOOGLE_CSE_ID=""

# ---------------------------------------------------------------------------
# Persistência PostgreSQL + MinIO (dados da empresa por office_token)
# Suba com: docker compose up -d
# Migre o schema: npm run storage:migrate
# ---------------------------------------------------------------------------
STORAGE_BACKEND=postgres
DATABASE_URL=postgresql://eye:eye@127.0.0.1:5432/eye_vision

MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=eyevision
MINIO_SECRET_KEY=eyevisionsecret
MINIO_BUCKET=eye-vision

# Frontend: usa a mesma base /api/agent (Vite proxy → :8790 quando agent-api sobe)
# VITE_STORAGE_BACKEND=postgres
# VITE_AGENT_API_URL=/api/agent
